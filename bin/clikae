#!/usr/bin/env bash
# clikae - CLI profile switcher  /  ｷﾘｶｴ (切り替え)
# https://github.com/CVERInc/clikae
# MIT License

set -eo pipefail

CLIKAE_VERSION="0.5.14"

# Resolve install root (handles symlink chains, e.g., via Homebrew)
__resolve_self() {
  local src="${BASH_SOURCE[0]}"
  while [ -h "$src" ]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ $src != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" && pwd
}

CLIKAE_BIN_DIR="$(__resolve_self)"
CLIKAE_ROOT="$(cd "$CLIKAE_BIN_DIR/.." && pwd)"
CLIKAE_LIB="$CLIKAE_ROOT/lib"
CLIKAE_BIN="$CLIKAE_BIN_DIR/clikae"   # this very binary, for self-invocation (e.g. `demo`)
export CLIKAE_VERSION CLIKAE_ROOT CLIKAE_LIB CLIKAE_BIN

# Profile store layout. Override with $CLIKAE_HOME if you want.
CLIKAE_HOME="${CLIKAE_HOME:-$HOME/.clikae}"
export CLIKAE_HOME

# Load core libs
# shellcheck source=../lib/core/log.sh
source "$CLIKAE_LIB/core/log.sh"
# shellcheck source=../lib/core/i18n.sh
source "$CLIKAE_LIB/core/i18n.sh"
# shellcheck source=../lib/core/json.sh
source "$CLIKAE_LIB/core/json.sh"
# shellcheck source=../lib/core/profile_store.sh
source "$CLIKAE_LIB/core/profile_store.sh"
# shellcheck source=../lib/core/shell_rc.sh
source "$CLIKAE_LIB/core/shell_rc.sh"
# shellcheck source=../lib/core/adapter_loader.sh
source "$CLIKAE_LIB/core/adapter_loader.sh"
# shellcheck source=../lib/core/handoff.sh
source "$CLIKAE_LIB/core/handoff.sh"
# shellcheck source=../lib/core/scan.sh
source "$CLIKAE_LIB/core/scan.sh"
# shellcheck source=../lib/core/dry_store.sh
source "$CLIKAE_LIB/core/dry_store.sh"
# shellcheck source=../lib/core/update_check.sh
source "$CLIKAE_LIB/core/update_check.sh"
# shellcheck source=../lib/core/limit.sh
source "$CLIKAE_LIB/core/limit.sh"
# shellcheck source=../lib/core/history.sh
source "$CLIKAE_LIB/core/history.sh"
# shellcheck source=../lib/core/autonomy.sh
source "$CLIKAE_LIB/core/autonomy.sh"
# shellcheck source=../lib/core/proc.sh
source "$CLIKAE_LIB/core/proc.sh"
# shellcheck source=../lib/core/state_version.sh
source "$CLIKAE_LIB/core/state_version.sh"

# Migrate the on-disk state forward if an older clikae last wrote it (no-op when the
# state is current or absent; read-only safe — see lib/core/state_version.sh).
state_version_check

# Subcommand dispatch (see docs/grammar.md §4). Resolve the first argument:
#   1. a reserved command (or alias) -> run it directly;
#   2. an installed engine (an adapter) -> the BARE SWITCH, `clikae <engine>
#      [tank]` (the verb is the program name, so none is typed);
#   3. anything else -> unknown.
# Bare `clikae` opens the home dashboard; the full reference is at `clikae help`.
raw="${1:-home}"

__clikae_is_reserved() {
  case "$1" in
    home|dashboard|doctor|demo|init|app|tanks|list|ls|status|remove|rm|run|burn|to|continue|relay|handoff|watch|auto|antigravity|agy|rename|alias|migrate|env|info|adapters|lang|help|--help|-h|version|--version|-v) return 0 ;;
    *) return 1 ;;
  esac
}

if __clikae_is_reserved "$raw"; then
  cmd="$raw"; shift || true
  case "$cmd" in
    tanks|ls)     cmd="list" ;;
    continue)     cmd="to" ;;
    rm)           cmd="remove" ;;
    dashboard)    cmd="home" ;;
    agy)          cmd="antigravity" ;;
    --help|-h)    cmd="help" ;;
    --version|-v) cmd="version" ;;
  esac
elif [ -f "$CLIKAE_LIB/adapters/$raw.sh" ]; then
  # Bare switch — keep "$@" intact: the engine is cmd_switch's first argument.
  cmd="switch"
else
  # Maybe it's a TANK NAME (scheme B): a tank's name is its identity, so
  # `clikae <name>` switches to it without naming the engine. Resolve across
  # engines; unique -> switch, ambiguous -> ask the user to qualify.
  __name_matches="$(resolve_tank_name "$raw" 2>/dev/null || true)"
  __name_n="$(printf '%s\n' "$__name_matches" | grep -c . || true)"
  if [ "$__name_n" -eq 1 ]; then
    __m_engine="$(printf '%s' "$__name_matches" | cut -f1)"
    __m_tank="$(printf '%s' "$__name_matches" | cut -f2)"
    shift || true   # drop the name; reshape into the canonical switch form
    if [ "$__m_engine" = "antigravity" ]; then
      set -- "$__m_tank" "$@"; cmd="antigravity"   # agy tanks switch via cmd_antigravity
    else
      set -- "$__m_engine" "$__m_tank" "$@"; cmd="switch"
    fi
  elif [ "$__name_n" -gt 1 ]; then
    log_err "Ambiguous tank name: $raw  (exists in more than one engine)"
    printf '%s\n' "$__name_matches" | while IFS=$'\t' read -r e t; do
      [ -n "$e" ] && log_dim "  clikae $e $t"
    done
    exit 1
  else
    log_err "Unknown command, engine, or tank: $raw"
    echo ""
    set --
    cmd="help"
  fi
fi

if [ "$cmd" = "version" ]; then
  echo "clikae $CLIKAE_VERSION"
  exit 0
fi

cmd_file="$CLIKAE_LIB/commands/$cmd.sh"
if [ ! -f "$cmd_file" ]; then
  log_err "Internal: command file not found: $cmd_file"
  exit 1
fi

# shellcheck source=/dev/null
source "$cmd_file"
"cmd_$cmd" "$@"
